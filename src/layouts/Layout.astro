---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "内含子生物科技 | Intron BioTech" } = Astro.props;
---

<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content="内含子生物科技(上海)有限公司，专注于分子生物学技术咨询、生物计算与 AI 工作流，为尖端生命科学研究提供智能化解决方案。" />
  </head>
  
  <body class="bg-[#020617] text-slate-200 font-sans antialiased selection:bg-cyan-500/30">
    
    <!-- 粒子背景 Canvas -->
    <canvas 
      id="particleCanvas" 
      class="fixed inset-0 w-full h-full -z-10 pointer-events-none"
    ></canvas>

    <div class="fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-cyan-900/10 blur-[120px]"></div>
      <div class="absolute top-[20%] -right-[10%] w-[30%] h-[50%] rounded-full bg-indigo-900/10 blur-[120px]"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6">
      
      <header class="flex justify-between items-center py-10 relative z-50">
        <a href="/" class="flex items-center gap-3 group">
          <img src="/favicon.svg" alt="IB Logo" class="w-8 h-8 object-contain transition-colors">
          <div class="text-xl font-bold tracking-tighter text-white">
            INTRON BIOTech <span class="hidden md:inline text-slate-500 font-medium ml-1">内含子生物</span>
          </div>
        </a>

        <nav class="hidden md:flex gap-10 text-xs uppercase tracking-[0.2em] text-slate-400 items-center">
          <a href="/#services" class="hover:text-cyan-400 transition-colors">Services / 业务</a>
          <a href="/#expertise" class="hover:text-cyan-400 transition-colors">Expertise / 核心</a>
          <a href="/news" class="hover:text-cyan-400 transition-colors">News / 资讯</a>
          <a href="/#contact" class="hover:text-cyan-400 transition-colors border border-slate-700 px-4 py-2 rounded-full hover:border-cyan-400">Contact / 联系</a>
          
          <a 
            href="https://chinabio.taobao.com" 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-slate-400 hover:text-cyan-400 transition-colors"
            title="淘宝店铺 - 质粒与荧光菌株"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
          </a>
        </nav>

        <div class="flex md:hidden items-center gap-4">
          <a 
            href="https://chinabio.taobao.com" 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-slate-400 hover:text-cyan-400 transition-colors"
            title="淘宝店铺"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
          </a>
          
          <button id="mobile-menu-btn" class="text-slate-400 hover:text-white p-2 focus:outline-none">
            <svg id="icon-hamburger" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 block">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 hidden">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </header>

      <div id="mobile-menu" class="fixed inset-0 bg-[#020617]/95 backdrop-blur-md z-40 hidden flex-col items-center justify-center gap-8 text-sm uppercase tracking-[0.2em] text-slate-300">
        <a href="/#services" class="mobile-link hover:text-cyan-400 transition-colors">Services / 业务</a>
        <a href="/#expertise" class="mobile-link hover:text-cyan-400 transition-colors">Expertise / 核心</a>
        <a href="/news" class="mobile-link hover:text-cyan-400 transition-colors">News / 资讯</a>
        <a href="/#contact" class="mobile-link text-cyan-400 border border-slate-700 px-8 py-3 rounded-full">Contact / 联系</a>
      </div>

      <slot /> 

      <footer id="contact" class="py-24 text-center">
      <div class="text-slate-500 space-y-2 text-sm">
        <div class="flex items-center justify-center gap-3 text-lg">
          <img 
            src="/favicon.svg" 
            alt="Logo" 
            class="w-6 h-6 object-contain"
          >
          内含子生物科技(上海)有限公司
        </div>
        <p>Intron Biotech (Shanghai) Co., Ltd.</p>
        <p class="pt-6 font-mono text-lg text-cyan-500/70 select-all">✉ sale@intronbio.tech</p>
        <p class="pt-6 font-mono text-lg text-cyan-500/70 select-all">☎ (+86)17501621170</p>
      </div>
      </footer>

    </div>

    <script>
      // 移动端菜单逻辑
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const iconHamburger = document.getElementById('icon-hamburger');
      const iconClose = document.getElementById('icon-close');
      const mobileLinks = document.querySelectorAll('.mobile-link');

      function toggleMenu() {
        if (mobileMenu) {
          mobileMenu.classList.toggle('hidden');
          mobileMenu.classList.toggle('flex');
          document.body.classList.toggle('overflow-hidden');
          iconHamburger.classList.toggle('hidden');
          iconHamburger.classList.toggle('block');
          iconClose.classList.toggle('hidden');
          iconClose.classList.toggle('block');
        }
      }

      if (mobileMenuBtn) {
        mobileMenuBtn.addEventListener('click', toggleMenu);
      }

      mobileLinks.forEach(link => {
        link.addEventListener('click', toggleMenu);
      });

      // 科技粒子背景效果
      const canvas = document.getElementById('particleCanvas');
      const ctx = canvas.getContext('2d');
      let w, h, particles;
      const mouse = { x: null, y: null, radius: 150 };

      function resize() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
        initParticles();
      }

      class Particle {
        constructor() {
          this.x = Math.random() * w;
          this.y = Math.random() * h;
          this.size = Math.random() * 1.8 + 0.4;
          this.speedX = Math.random() * 0.5 - 0.25;
          this.speedY = Math.random() * 0.5 - 0.25;
          this.color = 'rgba(125, 211, 255, 0.5)';
        }
        update() {
          this.x += this.speedX;
          this.y += this.speedY;

          if (this.x < 0 || this.x > w) this.speedX *= -1;
          if (this.y < 0 || this.y > h) this.speedY *= -1;

          const dx = this.x - mouse.x;
          const dy = this.y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < mouse.radius) {
            const force = (mouse.radius - dist) / mouse.radius;
            this.x -= dx * force * 0.3;
            this.y -= dy * force * 0.3;
          }
        }
        draw() {
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
          ctx.fillStyle = this.color;
          ctx.fill();
        }
      }

      function connect() {
        for (let a = 0; a < particles.length; a++) {
          for (let b = a; b < particles.length; b++) {
            const dx = particles[a].x - particles[b].x;
            const dy = particles[a].y - particles[b].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 140) {
              const opacity = 0.2 - dist / 700;
              ctx.strokeStyle = `rgba(125, 211, 255, ${opacity})`;
              ctx.lineWidth = 0.5;
              ctx.beginPath();
              ctx.moveTo(particles[a].x, particles[a].y);
              ctx.lineTo(particles[b].x, particles[b].y);
              ctx.stroke();
            }
          }
        }
      }

      function initParticles() {
        particles = [];
        for (let i = 0; i < 180; i++) {
          particles.push(new Particle());
        }
      }

      function animate() {
        ctx.clearRect(0, 0, w, h);
        particles.forEach(p => { p.update(); p.draw(); });
        connect();
        requestAnimationFrame(animate);
      }

      window.addEventListener('mousemove', (e) => {
        mouse.x = e.x;
        mouse.y = e.y;
      });

      resize();
      window.addEventListener('resize', resize);
      initParticles();
      animate();
    </script>
  </body>
</html>